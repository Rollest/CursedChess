@page "/"
@rendermode InteractiveServer

@using CursedChess.Application.Contracts
@using CursedChess.Domain.Entities
@using CursedChess.Domain.Rules
@using CursedChess.Components.Board

@inject ISolutionSearchService SolutionSearch
@inject ISolutionRepository SolutionRepository
@inject IBoardRepository BoardRepository

<PageTitle>Cursed Chess</PageTitle>

<style>
    .solutions-panel li.active-solution {
        background-color: #ffe8a3;
        border: 1px solid #e0b84f;
        border-radius: 6px;
        padding: 4px 8px;
        font-weight: 600;
    }

    .color-spec-panel {
        margin-top: 12px;
        padding-top: 12px;
        border-top: 1px solid rgba(0,0,0,0.08);
    }

    .color-spec-panel h4 {
        margin: 0 0 8px;
        font-size: 1rem;
    }

    .color-spec-row {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: 8px;
        margin-bottom: 10px;
        font-size: 0.9rem;
    }

    .color-spec-row input[type="color"] {
        width: 40px;
        height: 32px;
        padding: 0;
        border: 1px solid rgba(0,0,0,0.15);
        border-radius: 4px;
        cursor: pointer;
    }

    .color-spec-row .pct-hint {
        color: #555;
        font-size: 0.85rem;
    }

    .brush-row-selected {
        outline: 2px solid #2563eb;
        outline-offset: 2px;
        border-radius: 6px;
    }
</style>

<h1>Многоагентная доска</h1>

<div class="main-layout">
    <div class="settings-panel">
        <h3>Настройки</h3>
        <label>
            Размер доски N:
            <input type="number" min="1" @bind="boardSize" @bind:after="OnBoardSizeChanged" />
        </label>
        <div>
            <label>
                <input type="checkbox" @bind="requireSameColor" />
                Все агенты на клетках одного цвета
            </label>
        </div>
        <div>
            <label>
                Сортировка по стоимости:
                <select @bind="sortMode" @bind:after="OnSortModeChanged">
                    <option value="1">По возрастанию</option>
                    <option value="2">По убыванию</option>
                </select>
            </label>
        </div>
        <div class="color-spec-panel">
            <h4>Цвета клеток</h4>
            <div>
                <label>
                    <input type="checkbox" checked="@useAutomaticCellDistribution" @onchange="OnAutomaticDistributionChanged" />
                    Автоматическое распределение по долям
                </label>
            </div>
            @if (useAutomaticCellDistribution)
            {
                <p class="pct-hint" style="margin: 8px 0;">
                    Доли задают долю клеток каждого цвета (подбирается точное число клеток на доске). При изменении доска пересоздаётся.
                </p>
            }
            else
            {
                <p class="pct-hint" style="margin: 8px 0;">
                    Выберите кисть (цвет и цена строки) и режим клика по доске; клик по клетке закрашивает её. Доли в этом режиме не используются.
                </p>
                <div style="margin-bottom: 10px;">
                    <span class="pct-hint">Клик по доске:</span>
                    <label><input type="radio" name="boardClickMode" checked="@boardInteractionAgents" @onchange="@(_ => SetBoardInteractionAgents(true))" /> Фиксация агента</label>
                    <label><input type="radio" name="boardClickMode" checked="@(!boardInteractionAgents)" @onchange="@(_ => SetBoardInteractionAgents(false))" /> Закрашивание клетки</label>
                </div>
            }
            @for (var i = 0; i < 3; i++)
            {
                var index = i;
                <div class="color-spec-row @(useAutomaticCellDistribution ? "" : (selectedBrushIndex == index ? "brush-row-selected" : ""))">
                    @if (!useAutomaticCellDistribution)
                    {
                        <label class="pct-hint" title="Активная кисть">
                            <input type="radio" name="brushPick" checked="@(selectedBrushIndex == index)" @onchange="@(_ => { selectedBrushIndex = index; })" />
                            Кисть
                        </label>
                    }
                    <input type="color"
                           value="@cellColors[index]"
                           @onchange="@(e => OnCellColorPicked(index, e))" />
                    @if (useAutomaticCellDistribution)
                    {
                        <label>
                            Доля:
                            <input type="number" min="0" step="1" style="width: 4.5rem;"
                                   @bind="colorWeights[index]"
                                   @bind:after="OnAutoPaletteChanged" />
                        </label>
                        <span class="pct-hint">целевая доля ~@GetEffectivePercentLabel(index)%</span>
                    }
                    <label>
                        Цена:
                        <input type="number" min="0" step="0.01" style="width: 4.5rem;"
                               @bind="colorCosts[index]"
                               @bind:after="OnPaletteCostChanged" />
                    </label>
                </div>
            }
        </div>
        <div>
            <label>
                Активный агент:
                <select @bind="selectedAgentColumn">
                    @foreach (var agent in OrderedAgentsForEditing)
                    {
                        <option value="@agent.ColumnIndex">Агент (колонка @agent.ColumnIndex)</option>
                    }
                </select>
            </label>
        </div>
        <div class="priority-list">
            <h4>Приоритеты агентов</h4>
            @foreach (var agent in OrderedAgentsForEditing)
            {
                <div>
                    <span>Агент (колонка @agent.ColumnIndex)</span>
                    <input type="number" min="0" @bind="agent.Priority" />
                    <label>
                        <input type="checkbox" checked="@agent.IsFixed" @onchange="(e) => SetFixedFlag(agent, e)" />
                        Фиксирован
                    </label>
                </div>
            }
        </div>
        @if (!string.IsNullOrWhiteSpace(boardMessage))
        {
            <p>@boardMessage</p>
        }
        <button @onclick="RunSearch">Запустить поиск</button>
        <button @onclick="LoadSavedSolutions">Загрузить сохранённые решения</button>
        <button @onclick="LoadBoardFromDatabase">Загрузить последнюю доску из БД</button>
    </div>

    <div class="board-and-controls">
        <BoardView Board="board"
                   CurrentStep="CurrentStep"
                   FixedPositions="board.FixedPositions.ToList()"
                   SelectedAgentColumn="SelectedAgent?.ColumnIndex"
                   IsPaintMode="@(!useAutomaticCellDistribution && !boardInteractionAgents)"
                   OnCellClick="HandleBoardCellClick" />

        <div class="animation-controls">
            <div class="speed-row">
                <label>
                    Скорость (мс/шаг):
                    <input type="range" min="50" max="1500" step="50" @bind="stepDelayMs" />
                </label>
                <span class="speed-value">@stepDelayMs</span>
            </div>

            <button @onclick="StartFromBeginning" disabled="@_isPlaying">Начать</button>
            <button @onclick="ContinuePlayback" disabled="@(_isPlaying || steps.Count == 0 || currentStepIndex >= steps.Count - 1)">Продолжить</button>
            <button @onclick="Pause" disabled="@(!_isPlaying)">Пауза</button>
            <button @onclick="NextStep" disabled="@_isPlaying">Шаг вперёд</button>
            <button @onclick="PreviousStep" disabled="@_isPlaying">Шаг назад</button>
            <button @onclick="Reset" disabled="@(!_isPlaying && currentStepIndex == 0)">Сброс</button>
            <button @onclick="NextSolution" disabled="@_isPlaying">К следующему решению</button>
        </div>
    </div>

    <div class="solutions-panel">
        <h3>Решения (@solutions.Count)</h3>
        <ul>
            @for (var i = 0; i < solutions.Count; i++)
            {
                var s = solutions[i];
                <li class="@(i == CurrentSolutionListIndex ? "active-solution" : "")"
                    @onclick="() => ShowSolution(i)">
                    Решение @i: стоимость @s.TotalCost, цветовой фильтр: @(s.IsColorConsistent ? "да" : "нет")
                </li>
            }
        </ul>
    </div>
</div>

@code {
    @implements IDisposable
    private int boardSize = 4;
    private bool requireSameColor = false;
    private int sortMode = 1;
    private int selectedAgentColumn;
    private string? boardMessage;

    private string[] cellColors = ["#F54227", "#27E4F5", "#27F52E"];
    private int[] colorWeights = [33, 33, 34];
    private decimal[] colorCosts = [1m, 2m, 3m];
    private bool useAutomaticCellDistribution = true;
    private bool boardInteractionAgents = true;
    private int selectedBrushIndex;

    private Board board = new();
    private List<Solution> solutions = new();
    private List<SearchStep> steps = new();
    private List<int> solutionFoundStepIndices = new();
    private int currentStepIndex;

    private int stepDelayMs = 200;
    private CancellationTokenSource? playbackCts;
    private bool _isPlaying;

    private SearchStep? CurrentStep => steps.Count > 0 && currentStepIndex >= 0 && currentStepIndex < steps.Count
        ? steps[currentStepIndex]
        : null;
    private List<Agent> OrderedAgentsForEditing => board.Agents
        .OrderByDescending(a => a.IsFixed)
        .ThenBy(a => a.Priority)
        .ThenBy(a => a.ColumnIndex)
        .ToList();
    private Agent? SelectedAgent => board.Agents.FirstOrDefault(a => a.ColumnIndex == selectedAgentColumn);
    private int CurrentSolutionListIndex
    {
        get
        {
            if (solutionFoundStepIndices.Count == 0)
            {
                return -1;
            }

            for (var i = 0; i < solutionFoundStepIndices.Count; i++)
            {
                if (solutionFoundStepIndices[i] == currentStepIndex)
                {
                    return i;
                }
            }

            return -1;
        }
    }

    /// <summary>
    /// Выполняет начальную инициализацию страницы.
    /// </summary>
    protected override void OnInitialized()
    {
        InitializeBoard();
    }

    /// <summary>
    /// Останавливает текущее воспроизведение шагов.
    /// </summary>
    private void CancelPlayback()
    {
        try
        {
            playbackCts?.Cancel();
        }
        catch
        {
            // ignore
        }
        playbackCts?.Dispose();
        playbackCts = null;
        _isPlaying = false;
    }

    /// <summary>
    /// Последовательно проигрывает шаги трассировки с задержкой.
    /// </summary>
    /// <param name="token">Токен отмены воспроизведения.</param>
    /// <returns>Задача завершения цикла воспроизведения.</returns>
    private async Task PlaybackLoop(CancellationToken token)
    {
        _isPlaying = true;
        var startedFrom = currentStepIndex;
        try
        {
            for (var i = currentStepIndex; i < steps.Count; i++)
            {
                token.ThrowIfCancellationRequested();
                currentStepIndex = i;
                await InvokeAsync(StateHasChanged);

                if (steps[i].Type == SearchStepType.SolutionFound && i > startedFrom)
                {
                    break;
                }

                await Task.Delay(stepDelayMs, token);
            }
        }
        catch (OperationCanceledException)
        {
            // expected on pause/reset
        }
        finally
        {
            _isPlaying = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    /// <summary>
    /// Пересоздаёт доску после изменения размера N.
    /// </summary>
    /// <returns>Ничего не возвращает.</returns>
    private void OnBoardSizeChanged()
    {
        if (boardSize < 1)
        {
            boardSize = 1;
        }

        CancelPlayback();
        boardMessage = null;
        solutions = new List<Solution>();
        steps = new List<SearchStep>();
        solutionFoundStepIndices = new List<int>();
        currentStepIndex = 0;
        InitializeBoard();
    }

    /// <summary>
    /// Пересоздаёт доску после изменения палитры, долей или цен (только в режиме автоматического распределения).
    /// </summary>
    private void OnColorSettingsChanged()
    {
        if (!useAutomaticCellDistribution)
        {
            return;
        }

        CancelPlayback();
        boardMessage = null;
        solutions = new List<Solution>();
        steps = new List<SearchStep>();
        solutionFoundStepIndices = new List<int>();
        currentStepIndex = 0;
        InitializeBoard();
    }

    private void OnAutomaticDistributionChanged(ChangeEventArgs e)
    {
        useAutomaticCellDistribution = e.Value is bool b && b;
        if (useAutomaticCellDistribution)
        {
            OnColorSettingsChanged();
        }
        else
        {
            CancelPlayback();
            boardMessage = null;
            solutions = new List<Solution>();
            steps = new List<SearchStep>();
            solutionFoundStepIndices = new List<int>();
            currentStepIndex = 0;
            boardInteractionAgents = true;
            InitializeBoard();
        }
    }

    private void SetBoardInteractionAgents(bool agents)
    {
        boardInteractionAgents = agents;
    }

    private void OnAutoPaletteChanged()
    {
        OnColorSettingsChanged();
    }

    private void OnPaletteCostChanged()
    {
        if (useAutomaticCellDistribution)
        {
            OnColorSettingsChanged();
        }
    }

    private void OnCellColorPicked(int index, ChangeEventArgs e)
    {
        var v = e.Value?.ToString();
        if (!string.IsNullOrWhiteSpace(v))
        {
            cellColors[index] = v;
        }

        if (useAutomaticCellDistribution)
        {
            OnColorSettingsChanged();
        }
    }

    private string GetEffectivePercentLabel(int index)
    {
        var weights = colorWeights.Select(w => (decimal)Math.Max(0, w)).ToArray();
        var totalCells = boardSize * boardSize;
        if (totalCells == 0)
        {
            return "0";
        }

        var counts = DistributeCellCounts(totalCells, weights);
        var p = 100m * counts[index] / totalCells;
        return p.ToString("0.#", System.Globalization.CultureInfo.GetCultureInfo("ru-RU"));
    }

    /// <summary>
    /// Раскладывает total клеток по цветам пропорционально весам (остаток по наибольшим дробным частям).
    /// </summary>
    private static int[] DistributeCellCounts(int total, decimal[] weights)
    {
        var n = weights.Length;
        if (n == 0)
        {
            return Array.Empty<int>();
        }

        var sumW = weights.Sum();
        if (sumW <= 0)
        {
            weights = Enumerable.Repeat(1m / n, n).ToArray();
            sumW = 1m;
        }

        var norm = weights.Select(w => w / sumW).ToArray();
        var exact = norm.Select(w => (decimal)total * w).ToArray();
        var floors = exact.Select(x => (int)Math.Floor(x)).ToArray();
        var remainder = total - floors.Sum();
        var order = Enumerable.Range(0, n)
            .OrderByDescending(i => exact[i] - floors[i])
            .ToArray();
        var counts = floors.ToArray();
        for (var i = 0; i < remainder; i++)
        {
            counts[order[i]]++;
        }

        return counts;
    }

    private static void Shuffle<T>(IList<T> list)
    {
        for (var i = list.Count - 1; i > 0; i--)
        {
            var j = Random.Shared.Next(i + 1);
            (list[i], list[j]) = (list[j], list[i]);
        }
    }

    /// <summary>
    /// Создаёт стартовую доску выбранного размера.
    /// </summary>
    private void InitializeBoard()
    {
        var previousAgents = board.Agents
            .Select(a => new Agent
            {
                Id = a.Id,
                ColumnIndex = a.ColumnIndex,
                IsFixed = a.IsFixed,
                Priority = a.Priority
            })
            .ToDictionary(a => a.ColumnIndex, a => a);
        var previousFixed = board.FixedPositions
            .ToDictionary(fp => fp.Column, fp => fp.Row);

        var cells = new List<Cell>();
        if (useAutomaticCellDistribution)
        {
            var weights = colorWeights.Select(w => (decimal)Math.Max(0, w)).ToArray();
            var totalCells = boardSize * boardSize;
            var counts = DistributeCellCounts(totalCells, weights);
            var colorIndices = new List<int>(totalCells);
            for (var i = 0; i < 3; i++)
            {
                for (var k = 0; k < counts[i]; k++)
                {
                    colorIndices.Add(i);
                }
            }

            Shuffle(colorIndices);
            var cellIdx = 0;
            for (var r = 0; r < boardSize; r++)
            {
                for (var c = 0; c < boardSize; c++)
                {
                    var ci = colorIndices[cellIdx++];
                    cells.Add(new Cell
                    {
                        Row = r,
                        Column = c,
                        Cost = colorCosts[ci],
                        Color = cellColors[ci]
                    });
                }
            }
        }
        else
        {
            var oldMap = board.Cells.Count > 0
                ? board.Cells.ToDictionary(x => (x.Row, x.Column))
                : new Dictionary<(int Row, int Col), Cell>();
            for (var r = 0; r < boardSize; r++)
            {
                for (var c = 0; c < boardSize; c++)
                {
                    if (oldMap.TryGetValue((r, c), out var oldCell))
                    {
                        cells.Add(new Cell
                        {
                            Row = r,
                            Column = c,
                            Cost = oldCell.Cost,
                            Color = oldCell.Color
                        });
                    }
                    else
                    {
                        cells.Add(new Cell
                        {
                            Row = r,
                            Column = c,
                            Cost = colorCosts[0],
                            Color = cellColors[0]
                        });
                    }
                }
            }
        }

        var agents = new List<Agent>();
        for (var c = 0; c < boardSize; c++)
        {
            if (previousAgents.TryGetValue(c, out var existing))
            {
                agents.Add(new Agent
                {
                    ColumnIndex = c,
                    IsFixed = existing.IsFixed,
                    Priority = existing.Priority
                });
            }
            else
            {
                agents.Add(new Agent
                {
                    ColumnIndex = c,
                    IsFixed = false,
                    Priority = c
                });
            }
        }

        var fixedPositions = new List<FixedPosition>();
        foreach (var agent in agents.Where(a => a.IsFixed))
        {
            if (previousFixed.TryGetValue(agent.ColumnIndex, out var fixedRow))
            {
                fixedPositions.Add(new FixedPosition
                {
                    Agent = agent,
                    Row = fixedRow,
                    Column = agent.ColumnIndex
                });
            }
        }

        board = new Board
        {
            Size = boardSize,
            Cells = cells,
            Agents = agents,
            FixedPositions = fixedPositions
        };
        selectedAgentColumn = board.Agents.OrderBy(a => a.ColumnIndex).FirstOrDefault()?.ColumnIndex ?? 0;
    }

    /// <summary>
    /// Запускает поиск решений и сохраняет результаты.
    /// </summary>
    /// <returns>Задача завершения поиска и сохранения.</returns>
    private async Task RunSearch()
    {
        try
        {
            CancelPlayback();
            boardMessage = null;
            SyncFixedPositionsWithAgents();

            var rules = new List<IConflictRule>();
            rules.Add(new RowConflictRule());
            rules.Add(new DiagonalConflictRule());

            await BoardRepository.SaveBoardAsync(board);
            boardMessage = $"Доска сохранена в БД, Id = {board.Id} (цвета и стоимость клеток — в таблице Cells).";
            var result = SolutionSearch.FindSolutions(board, rules, requireSameColor);
            foreach (var solution in result.solutions)
            {
                solution.BoardId = board.Id;
            }
            await SolutionRepository.SaveSolutionsAsync(result.solutions);

            solutions = result.solutions.ToList();
            ApplySort();
            steps = result.steps.ToList();
            currentStepIndex = 0;

            solutionFoundStepIndices = BuildSolutionStepIndicesForDisplayedSolutions();
        }
        catch (Exception ex)
        {
            boardMessage = $"Ошибка поиска: {ex.Message}";
        }
    }

    /// <summary>
    /// Поднимает последнюю сохранённую доску из БД (включая цвета и цены клеток).
    /// </summary>
    private async Task LoadBoardFromDatabase()
    {
        try
        {
            CancelPlayback();
            boardMessage = null;
            var loaded = await BoardRepository.GetLatestBoardAsync();
            if (loaded is null)
            {
                boardMessage = "В базе нет сохранённых досок.";
                return;
            }

            boardSize = loaded.Size;
            useAutomaticCellDistribution = false;
            boardInteractionAgents = true;
            board = loaded;
            selectedAgentColumn = board.Agents.OrderBy(a => a.ColumnIndex).FirstOrDefault()?.ColumnIndex ?? 0;

            solutions = new List<Solution>();
            steps = new List<SearchStep>();
            solutionFoundStepIndices = new List<int>();
            currentStepIndex = 0;

            boardMessage = $"Загружена доска Id = {board.Id}, клеток: {board.Cells.Count}. Режим: ручная раскраска (цвета из БД).";
        }
        catch (Exception ex)
        {
            boardMessage = $"Ошибка загрузки доски: {ex.Message}";
        }
    }

    /// <summary>
    /// Загружает сохранённые решения для текущей доски.
    /// </summary>
    /// <returns>Задача завершения загрузки решений.</returns>
    private async Task LoadSavedSolutions()
    {
        try
        {
            CancelPlayback();
            if (board.Id == 0)
            {
                return;
            }

            var saved = await SolutionRepository.GetSolutionsForBoardAsync(board.Id);
            solutions = saved.ToList();
            ApplySort();

            // Для отображения на доске создаём "одношаговые" снапшоты без журнала перебора.
            steps = solutions
                .Select((s, idx) => new SearchStep
                {
                    Index = idx,
                    Type = SearchStepType.SolutionFound,
                    ActiveAgentColumn = 0,
                    Row = null,
                    Column = null,
                    Comment = "Загруженное решение",
                    AgentPositionsSnapshot = s.Items.Select(it => new Position(it.Row, it.Column)).ToList()
                })
                .ToList();

            solutionFoundStepIndices = Enumerable.Range(0, steps.Count).ToList();
            currentStepIndex = 0;
        }
        catch (Exception ex)
        {
            boardMessage = $"Ошибка загрузки: {ex.Message}";
        }
    }

    /// <summary>
    /// Запускает воспроизведение шагов с начала.
    /// </summary>
    /// <returns>Задача завершения запуска воспроизведения.</returns>
    private async Task StartFromBeginning()
    {
        if (steps.Count == 0)
        {
            return;
        }

        CancelPlayback();
        currentStepIndex = 0;
        playbackCts = new CancellationTokenSource();
        await PlaybackLoop(playbackCts.Token);
    }

    /// <summary>
    /// Ставит воспроизведение на паузу.
    /// </summary>
    private void Pause()
    {
        CancelPlayback();
    }

    /// <summary>
    /// Продолжает воспроизведение с текущего шага.
    /// </summary>
    /// <returns>Задача завершения продолжения воспроизведения.</returns>
    private async Task ContinuePlayback()
    {
        if (_isPlaying || steps.Count == 0)
        {
            return;
        }

        CancelPlayback();
        playbackCts = new CancellationTokenSource();
        await PlaybackLoop(playbackCts.Token);
    }

    /// <summary>
    /// Переключает отображение на следующий шаг.
    /// </summary>
    private void NextStep()
    {
        if (_isPlaying)
        {
            return;
        }

        CancelPlayback();
        if (currentStepIndex < steps.Count - 1)
        {
            currentStepIndex++;
        }
        StateHasChanged();
    }

    /// <summary>
    /// Переключает отображение на предыдущий шаг.
    /// </summary>
    private void PreviousStep()
    {
        if (_isPlaying)
        {
            return;
        }

        CancelPlayback();
        if (currentStepIndex > 0)
        {
            currentStepIndex--;
        }
        StateHasChanged();
    }

    /// <summary>
    /// Сбрасывает воспроизведение к начальному состоянию.
    /// </summary>
    private void Reset()
    {
        CancelPlayback();
        currentStepIndex = 0;
        StateHasChanged();
    }

    /// <summary>
    /// Переходит к следующему найденному решению.
    /// </summary>
    private void NextSolution()
    {
        if (solutionFoundStepIndices.Count == 0)
        {
            return;
        }

        CancelPlayback();
        var currentListIndex = CurrentSolutionListIndex;
        if (currentListIndex < 0)
        {
            currentStepIndex = solutionFoundStepIndices[0];
        }
        else
        {
            var nextListIndex = Math.Min(currentListIndex + 1, solutionFoundStepIndices.Count - 1);
            currentStepIndex = solutionFoundStepIndices[nextListIndex];
        }

        StateHasChanged();
    }

    /// <summary>
    /// Показывает выбранное решение по его индексу.
    /// </summary>
    /// <param name="index">Индекс решения в списке.</param>
    private void ShowSolution(int index)
    {
        if (index < 0 || index >= solutionFoundStepIndices.Count)
        {
            currentStepIndex = 0;
            return;
        }

        CancelPlayback();
        currentStepIndex = solutionFoundStepIndices[index];
        StateHasChanged();
    }

    /// <summary>
    /// Освобождает ресурсы воспроизведения при закрытии компонента.
    /// </summary>
    public void Dispose()
    {
        CancelPlayback();
    }

    /// <summary>
    /// Обрабатывает клик по клетке и фиксирует позицию активного агента.
    /// </summary>
    /// <param name="position">Позиция выбранной клетки.</param>
    /// <returns>Задача завершения обработки клика.</returns>
    private Task HandleBoardCellClick(Position position)
    {
        boardMessage = null;

        if (!useAutomaticCellDistribution && !boardInteractionAgents)
        {
            var cell = board.Cells.FirstOrDefault(x => x.Row == position.Row && x.Column == position.Column);
            if (cell is null)
            {
                return Task.CompletedTask;
            }

            var i = selectedBrushIndex;
            if (i < 0 || i > 2)
            {
                i = 0;
            }

            cell.Color = cellColors[i];
            cell.Cost = colorCosts[i];
            return Task.CompletedTask;
        }

        var agent = SelectedAgent;
        if (agent is null)
        {
            boardMessage = "Сначала выберите активного агента.";
            return Task.CompletedTask;
        }

        if (position.Column != agent.ColumnIndex)
        {
            boardMessage = $"Агент в колонке {agent.ColumnIndex} может быть зафиксирован только в своей колонке.";
            return Task.CompletedTask;
        }

        var current = board.FixedPositions.FirstOrDefault(fp => fp.Column == agent.ColumnIndex);
        if (current is not null && current.Row == position.Row)
        {
            board.FixedPositions.Remove(current);
            agent.IsFixed = false;
            return Task.CompletedTask;
        }

        if (current is null)
        {
            current = new FixedPosition { Agent = agent, Column = agent.ColumnIndex };
            board.FixedPositions.Add(current);
        }

        current.Row = position.Row;
        current.Column = agent.ColumnIndex;
        agent.IsFixed = true;
        return Task.CompletedTask;
    }

    /// <summary>
    /// Переключает признак фиксированной позиции для агента.
    /// </summary>
    /// <param name="agent">Агент, для которого меняется признак фиксации.</param>
    /// <param name="args">Аргументы события изменения.</param>
    /// <returns>Ничего не возвращает.</returns>
    private void SetFixedFlag(Agent agent, ChangeEventArgs args)
    {
        var isChecked = args.Value is bool value && value;
        agent.IsFixed = isChecked;

        var current = board.FixedPositions.FirstOrDefault(fp => fp.Column == agent.ColumnIndex);
        if (!isChecked)
        {
            if (current is not null)
            {
                board.FixedPositions.Remove(current);
            }
            return;
        }

        if (current is null)
        {
            board.FixedPositions.Add(new FixedPosition
            {
                Agent = agent,
                Column = agent.ColumnIndex,
                Row = 0
            });
        }
    }

    /// <summary>
    /// Синхронизирует список фиксированных позиций с состоянием агентов.
    /// </summary>
    /// <returns>Ничего не возвращает.</returns>
    private void SyncFixedPositionsWithAgents()
    {
        var fixedByColumn = board.FixedPositions
            .GroupBy(fp => fp.Column)
            .ToDictionary(g => g.Key, g => g.First());
        board.FixedPositions = board.Agents
            .Where(a => a.IsFixed)
            .Select(a =>
            {
                if (fixedByColumn.TryGetValue(a.ColumnIndex, out var existing))
                {
                    existing.Column = a.ColumnIndex;
                    existing.Agent = a;
                    return existing;
                }

                return new FixedPosition
                {
                    Agent = a,
                    Column = a.ColumnIndex,
                    Row = 0
                };
            })
            .ToList();
    }

    /// <summary>
    /// Применяет сортировку списка решений по выбранному режиму.
    /// </summary>
    /// <returns>Ничего не возвращает.</returns>
    private void ApplySort()
    {
        solutions = sortMode == 2
            ? solutions.OrderByDescending(s => s.TotalCost).ToList()
            : solutions.OrderBy(s => s.TotalCost).ToList();
    }

    /// <summary>
    /// Применяет сортировку сразу после изменения режима в интерфейсе.
    /// </summary>
    /// <returns>Ничего не возвращает.</returns>
    private void OnSortModeChanged()
    {
        ApplySort();
        solutionFoundStepIndices = BuildSolutionStepIndicesForDisplayedSolutions();
    }

    /// <summary>
    /// Строит соответствие "решение в текущем списке справа" -> индекс шага SolutionFound в журнале.
    /// Это нужно, чтобы клик по решению работал корректно после сортировки списка решений.
    /// </summary>
    private List<int> BuildSolutionStepIndicesForDisplayedSolutions()
    {
        var foundStepsByKey = steps
            .Select((s, idx) => new { s, idx })
            .Where(x => x.s.Type == SearchStepType.SolutionFound)
            .GroupBy(x => BuildKeyFromPositions(x.s.AgentPositionsSnapshot))
            .ToDictionary(
                g => g.Key,
                g => new Queue<int>(g.Select(x => x.idx)));

        var mapping = new List<int>(solutions.Count);
        foreach (var solution in solutions)
        {
            var key = BuildKeyFromPositions(solution.Items.Select(i => new Position(i.Row, i.Column)));
            if (foundStepsByKey.TryGetValue(key, out var queue) && queue.Count > 0)
            {
                mapping.Add(queue.Dequeue());
            }
        }

        return mapping;
    }

    /// <summary>
    /// Формирует стабильный ключ набора позиций, независимый от порядка элементов.
    /// </summary>
    private static string BuildKeyFromPositions(IEnumerable<Position> positions)
    {
        return string.Join("|", positions
            .OrderBy(p => p.Column)
            .ThenBy(p => p.Row)
            .Select(p => $"{p.Row},{p.Column}"));
    }
}
